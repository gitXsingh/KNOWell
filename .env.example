# === Backend Config ===
APP_ENV=development
APP_ADDR=:8080
DATABASE_URL=
MIGRATIONS_DIR=./migrations
JWT_ACCESS_TTL=24h

# === Security — generate your own secrets ===
JWT_SECRET=
GITHUB_TOKEN_SECRET=

# === GitHub OAuth ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
GITHUB_FRONTEND_CALLBACK_URL=
GITHUB_SCOPES=read:user repo admin:repo_hook
GITHUB_STATE_TTL=10m
GITHUB_WEBHOOK_URL=

# === CORS ===
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# === AI / Gemini ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# === Frontend ===
VITE_API_BASE=http://localhost:8080
